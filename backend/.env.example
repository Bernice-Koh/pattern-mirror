# --- runtime ---
# One of: development, test, production. Drives logging format and debug behaviour.
APP_ENV=development

# --- database ---
# Local dev points at the docker-compose Postgres in deploy/docker-compose.yml.
DATABASE_URL=postgresql+psycopg://mirror:mirror@localhost:5432/pattern_mirror

# The test suite targets this database instead of DATABASE_URL, so tests never
# collide with dev data. The suite migrates it automatically. Leave unset in CI,
# where DATABASE_URL already points at a clean container.
TEST_DATABASE_URL=postgresql+psycopg://mirror:mirror@localhost:5432/pattern_mirror_test

# --- LLM ---
# Anthropic API key — console.anthropic.com. Used by the Contextual Pass,
# Judge, and Recommendations stages. Never appears anywhere else.
ANTHROPIC_API_KEY=

# Models are config, not code, so the Judge and analysis models can be swapped
# (or pointed at the post-MVP multi-model gateway) without touching the engine.
ANALYSIS_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-haiku-4-5

# --- engine ---
# Judge confidence threshold below which flags terminate and recommendations
# are not generated. Tuned against the gold set; keep in config for the demo.
JUDGE_CONFIDENCE_THRESHOLD=0.7

# --- blob storage ---
# Local dev writes document blobs to a local folder (or Azurite if running it).
# Production uses an Azure Blob connection string. Same variable, different value.
BLOB_STORAGE_PATH=./deploy/blob-data
AZURE_STORAGE_CONNECTION_STRING=

# --- logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
